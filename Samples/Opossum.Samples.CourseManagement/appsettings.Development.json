{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",

      // Development: "Debug" shows per-projection rebuild progress and every
      // polling tick that processes events — useful when building new projections
      // or diagnosing lag. Switch to "Information" to simulate production noise levels.
      "Opossum": "Debug"
      //"Opossum": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Opossum": {
    "RootPath": "D:\\Database",
    "StoreName": "Medium",
    "FlushEventsImmediately": true,
    "WriteProtectEventFiles": false,
    "WriteProtectProjectionFiles": false
  },

  "Projections": {
    //"AutoRebuild": "MissingCheckpointsOnly",
    "AutoRebuild": "ForceFullRebuild",
    "MaxConcurrentRebuilds": 4,
    "PollingInterval": "00:00:05",
    "BatchSize": 500,
    "RebuildBatchSize": 500,
    "RebuildFlushInterval": 10000
  }
}
